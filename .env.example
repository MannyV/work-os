# Environment Variables — WorkOS Automation Engine
# Copy this file to .env and fill in your values.
# .env is git-ignored and must NEVER be committed.

# ── Notion API ───────────────────────────────────────────────────────────────
NOTION_API_KEY=xxx

# ── Database IDs (grab from each Notion database URL) ───────────────────────
# Format: https://www.notion.so/{workspace}/{DATABASE_ID}?v=...
NOTION_INBOX_DB_ID=xxx
NOTION_OKRS_DB_ID=xxx
NOTION_WORKSTREAMS_DB_ID=xxx

# ── Runtime ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
